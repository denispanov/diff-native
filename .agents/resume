#!/usr/bin/env bash
set -euo pipefail

BUN_VERSION="1.3.14"
RUST_VERSION="1.97.1"
WASM_PACK_VERSION="0.15.0"

# This project has no persistent services. Repair tool links so non-login shells
# can find toolchains installed in the user's home directory after an orb wakes.
mkdir -p "$HOME/.local/bin"

if [[ ! -x "$HOME/.bun/bin/bun" ]] || \
  [[ "$("$HOME/.bun/bin/bun" --version)" != "$BUN_VERSION" ]]; then
  echo "Expected Bun $BUN_VERSION; rerun .agents/setup" >&2
  exit 1
fi
ln -sf "$HOME/.bun/bin/bun" "$HOME/.local/bin/bun"
ln -sf "$HOME/.bun/bin/bunx" "$HOME/.local/bin/bunx"

if [[ ! -x "$HOME/.cargo/bin/rustc" ]] || \
  [[ "$("$HOME/.cargo/bin/rustc" --version)" != "rustc $RUST_VERSION "* ]]; then
  echo "Expected Rust $RUST_VERSION; rerun .agents/setup" >&2
  exit 1
fi

if [[ ! -x "$HOME/.cargo/bin/wasm-pack" ]] || \
  [[ "$("$HOME/.cargo/bin/wasm-pack" --version)" != "wasm-pack $WASM_PACK_VERSION" ]]; then
  echo "Expected wasm-pack $WASM_PACK_VERSION; rerun .agents/setup" >&2
  exit 1
fi

for tool in cargo clippy-driver rustc rustdoc rustfmt rustup wasm-pack; do
  if [[ -x "$HOME/.cargo/bin/$tool" ]]; then
    ln -sf "$HOME/.cargo/bin/$tool" "$HOME/.local/bin/$tool"
  fi
done

echo "Orb resume complete; no services to restart."
