#!/usr/bin/env bash
set -euo pipefail

BUN_VERSION="1.3.14"
RUST_VERSION="1.97.1"
WASM_PACK_VERSION="0.15.0"

echo "==> Installing system build dependencies"
sudo apt-get update
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y \
  build-essential \
  ca-certificates \
  curl \
  libssl-dev \
  pkg-config \
  unzip

mkdir -p "$HOME/.local/bin"

if [[ ! -x "$HOME/.bun/bin/bun" ]] || \
  [[ "$("$HOME/.bun/bin/bun" --version)" != "$BUN_VERSION" ]]; then
  echo "==> Installing Bun $BUN_VERSION"
  curl -fsSL https://bun.sh/install | bash -s -- "bun-v$BUN_VERSION"
fi

if [[ -x "$HOME/.bun/bin/bun" ]]; then
  ln -sf "$HOME/.bun/bin/bun" "$HOME/.local/bin/bun"
  ln -sf "$HOME/.bun/bin/bunx" "$HOME/.local/bin/bunx"
fi

if ! command -v rustup >/dev/null 2>&1; then
  echo "==> Installing Rust $RUST_VERSION"
  curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs | \
    sh -s -- -y --profile minimal --default-toolchain "$RUST_VERSION"
fi

export PATH="$HOME/.cargo/bin:$HOME/.bun/bin:$HOME/.local/bin:$PATH"

echo "==> Configuring Rust for WebAssembly builds"
rustup toolchain install "$RUST_VERSION" --profile minimal \
  --component clippy --component rustfmt \
  --target wasm32-unknown-unknown
rustup default "$RUST_VERSION"

echo "==> Installing wasm-pack $WASM_PACK_VERSION"
if ! command -v wasm-pack >/dev/null 2>&1 || \
  [[ "$(wasm-pack --version)" != "wasm-pack $WASM_PACK_VERSION" ]]; then
  cargo install wasm-pack --version "$WASM_PACK_VERSION" --locked
fi

for tool in cargo clippy-driver rustc rustdoc rustfmt rustup wasm-pack; do
  if [[ -x "$HOME/.cargo/bin/$tool" ]]; then
    ln -sf "$HOME/.cargo/bin/$tool" "$HOME/.local/bin/$tool"
  fi
done

[[ "$(bun --version)" == "$BUN_VERSION" ]]
[[ "$(rustc --version)" == "rustc $RUST_VERSION "* ]]
[[ "$(wasm-pack --version)" == "wasm-pack $WASM_PACK_VERSION" ]]

echo "==> Installing JavaScript dependencies"
bun install --frozen-lockfile

echo "==> Installing Playwright Chromium"
bun run playwright install --with-deps chromium

echo "==> Orb setup complete"
